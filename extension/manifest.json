{
  "manifest_version": 3,
  "name": "BingeBreak",
  "version": "0.3.0",
  "description": "Spoiler-free in-episode stopping points — pause right after the story lands, before the cliffhanger hook.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.tvmaze.com/*",
    "https://en.wikipedia.org/*",
    "https://api.gestdown.info/*",
    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://*.hf.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.netflix.com/*",
        "https://*.hulu.com/*",
        "https://*.disneyplus.com/*",
        "https://*.max.com/*",
        "https://*.hbomax.com/*",
        "https://*.primevideo.com/*",
        "https://*.amazon.com/*",
        "https://*.crunchyroll.com/*",
        "https://*.paramountplus.com/*",
        "https://*.peacocktv.com/*",
        "https://tv.apple.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/guard.js", "lib/detect.js"],
      "matches": [
        "https://*.netflix.com/*",
        "https://*.hulu.com/*",
        "https://*.disneyplus.com/*",
        "https://*.max.com/*",
        "https://*.hbomax.com/*",
        "https://*.primevideo.com/*",
        "https://*.amazon.com/*",
        "https://*.crunchyroll.com/*",
        "https://*.paramountplus.com/*",
        "https://*.peacocktv.com/*",
        "https://tv.apple.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
